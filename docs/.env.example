# ============================================================
# GoPilot - Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env files to version control.
# ============================================================

# ============================================================
# BACKEND ENVIRONMENT
# ============================================================
NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gopilot

# JWT Secrets (generate strong random strings, min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRE=7d

# CORS Allowed Origins
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ImageKit (Image Upload)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Brevo / Sendinblue (Email)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@yourdomain.com

# Razorpay (Payments)
RAZORPAY_KEY_ID=your_razorpay_test_or_live_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================================
# FRONTEND ENVIRONMENT
# ============================================================
VITE_API_URL=http://localhost:4000/api

# ============================================================
# ADMIN ENVIRONMENT
# ============================================================
VITE_API_URL=http://localhost:4000/api
