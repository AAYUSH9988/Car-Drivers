# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/gopilot?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-char-minimum-jwt-secret-here-change-this
JWT_REFRESH_SECRET=another-32-char-minimum-secret-here-change-this
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# App URLs
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ImageKit
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id

# Brevo (email)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@gopilot.app

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Admin seeding (optional)
ADMIN_SECRET=a-secret-key-for-seeding-admin-accounts
